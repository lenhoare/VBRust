' An Image control shows a picture from a path. Iced's `image` feature is added
' to the project automatically when you use it.
Window Gallery
    Title "Gallery"

    State
        Dim caption As String = "Ferris the crab"
    End State

    View
        Column
            Spacing 10
            Padding 20
            Text "My picture:"
            Image "ferris.png"
            Text caption
        End Column
    End View
End Window

Function Main()
    Gallery.Run
End Function
