' Standard library — file I/O and regex. Calls translate `.` to `::`.
Function Main()
    FileSystem.Write("greeting.txt", "Hello   from   VBR").Unwrap()

    Dim text As String = FileSystem.Read("greeting.txt").Unwrap()
    Debug.Print "file says: " & text

    Dim cleaned As String = Regex.ReplaceAll("\s+", text, " ").Unwrap()
    Debug.Print "cleaned:   " & cleaned

    FileSystem.Delete("greeting.txt").Unwrap()
End Function
